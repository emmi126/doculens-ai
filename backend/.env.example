# Database Configuration
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://doculens:password@localhost:5432/doculens

# Auth0 Configuration
# Get these from your Auth0 dashboard: https://manage.auth0.com/
# Domain: Your Auth0 tenant domain (e.g., your-tenant.auth0.com)
AUTH0_DOMAIN=your-domain.auth0.com
# Audience: Your API identifier from Auth0 API settings
AUTH0_AUDIENCE=your-api-audience

# Google Cloud Vision API
# Path to your Google Cloud service account JSON key file
# Can be absolute or relative to backend directory
GOOGLE_APPLICATION_CREDENTIALS=credentials/your-service-account-key.json

# Anthropic API
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Application Configuration
# Debug mode (set to false in production)
# DOCULENS_DEBUG=true

# Local fallback for OCR/LLM when credentials are missing or provider calls fail.
# Defaults to DEBUG when unset. Set false to require real AI credentials.
# ENABLE_DEMO_AI_FALLBACK=true

# Upload directory (default: uploads)
# UPLOAD_DIR=uploads

# Maximum file size in bytes (default: 10MB)
# MAX_FILE_SIZE=10485760
